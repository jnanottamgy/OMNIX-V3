# ═══════════════════════════════════════════════════════
# OMNIX V3 — Environment Variables
# Copy this to .env and fill your values
# ═══════════════════════════════════════════════════════

# LLM — Free Gemini at aistudio.google.com
GEMINI_API_KEY=AIzaSyA13fXZvmxtfqwB5Uff0Y-VyyA56HBmvdM
OPENAI_API_KEY=your_openai_api_key_here

# Google OAuth — console.cloud.google.com
# Enable: Calendar API + Gmail API
# Redirect URI: http://localhost:8000/integrations/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/integrations/google/callback

# Strava OAuth — strava.com/settings/api
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:8000/integrations/strava/callback

# Frontend URL (where index.html is served from)
FRONTEND_URL=http://localhost:5500

# Server
PORT=8000
HOST=0.0.0.0
